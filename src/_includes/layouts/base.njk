<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.title }}</title>
<meta name="description" content="{{ description or 'Work that asks the audience to do half of it. Films, installations, sound pieces, and mixed-reality experiences by Kit Monkman.' }}">
<link rel="stylesheet" href="/style.css">
</head>
<body>

<nav class="nav-wrap" aria-label="Sections">
  <div class="masthead-nav">
    <a class="wordmark" href="/">Kit Monkman</a>
    <div class="nav-links">
      {% for item in site.nav %}
        <a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.text }}</a>
      {% endfor %}
    </div>
  </div>
</nav>

{{ content | safe }}

<footer class="site-footer">
  <div class="nav-wrap">
    <nav class="footer-nav" aria-label="Sections">
      <div class="nav-links">
        {% for item in site.nav %}
          <a href="{{ item.url }}">{{ item.text }}</a>
        {% endfor %}
      </div>
      <p class="colophon">Kit Monkman &middot; York &middot; commercial work at <a href="https://viridianfx.co.uk">ViridianFX</a></p>
    </nav>
  </div>
</footer>

<script data-goatcounter="https://kitmonkman.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

</body>
</html>
